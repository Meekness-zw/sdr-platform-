# Copy this file to .env and fill in your values.
# NEVER commit the real .env file — it is in .gitignore.

# ── Gmail (required for sending + reply detection) ────────────────────────────
GMAIL_ADDRESS=you@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx   # from myaccount.google.com/security
SENDER_NAME=Your Name

# ── AI (required for opener generation + sentiment) ──────────────────────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# ── Alerts ────────────────────────────────────────────────────────────────────
SLACK_WEBHOOK_URL=        # from api.slack.com/messaging/webhooks
SLACK_CHANNEL_HOT_LEADS=#hot-leads

# ── Server ────────────────────────────────────────────────────────────────────
BASE_URL=http://localhost:8000   # change to your public URL when deployed
CALENDLY_LINK=https://calendly.com/yourname/30min

# ── Optional / paid tier integrations ────────────────────────────────────────
APOLLO_API_KEY=           # only needed for API sourcing (CSV upload works without)
CRUNCHBASE_API_KEY=
HUBSPOT_ACCESS_TOKEN=
WEBHOOK_SECRET=           # optional HMAC secret for Instantly webhooks
